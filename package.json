{
  "name": "@kalanda/gpxvideostudio",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "scripts/*"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "tsc",
    "prepare": "husky",
    "commitlint": "commitlint",
    "biome:format": "biome format",
    "biome:format:fix": "biome format --write .",
    "biome:lint": "biome lint .",
    "biome:lint:fix": "biome lint --write .",
    "biome:lint:unsafe": "biome lint --unsafe --write .",
    "i18n:check-unused-translations": "tsx scripts/check-unused-translations.ts --srcPath ./src --localeFile ./src/locales/en_US.json && tsx scripts/check-unused-translations.ts --srcPath ./src --localeFile ./src/locales/es_ES.json",
    "i18n:check-locales-structure": "tsx scripts/check-locales-structure.ts --localesDir ./src/locales --referenceLocale en_US"
  },
  "dependencies": {
    "@arcgis/core": "5.0.15",
    "@deck.gl/core": "9.2.11",
    "@deck.gl/extensions": "9.2.11",
    "@deck.gl/geo-layers": "9.2.11",
    "@deck.gl/layers": "9.2.11",
    "@deck.gl/mesh-layers": "9.2.11",
    "@deck.gl/react": "9.2.11",
    "@deck.gl/widgets": "9.2.11",
    "@heroui/react": "2.8.9",
    "@hookform/resolvers": "5.2.2",
    "@humanwhocodes/momoa": "1.0.0",
    "@loaders.gl/core": "4.3.4",
    "@luma.gl/core": "9.2.6",
    "@luma.gl/engine": "9.2.6",
    "@luma.gl/shadertools": "9.2.6",
    "@remotion/google-fonts": "4.0.443",
    "@remotion/media": "4.0.443",
    "@remotion/player": "4.0.443",
    "@remotion/web-renderer": "4.0.443",
    "@turf/bbox": "7.3.4",
    "@turf/bearing": "7.3.4",
    "@turf/distance": "7.3.4",
    "@turf/helpers": "7.3.4",
    "@turf/length": "7.3.4",
    "clsx": "2.1.1",
    "colorjs.io": "0.6.1",
    "date-fns": "4.1.0",
    "framer-motion": "12.34.3",
    "geojson": "0.5.0",
    "i18next": "25.8.11",
    "i18next-browser-languagedetector": "^8.2.1",
    "linkedom": "0.18.12",
    "lucide-react": "0.577.0",
    "mapbox-gl": "3.19.1",
    "maplibre-gl": "5.19.0",
    "react": "19.2.4",
    "react-color": "2.19.3",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.2",
    "react-i18next": "16.5.4",
    "react-map-gl": "8.1.0",
    "react-use": "17.6.0",
    "remotion": "4.0.443",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@biomejs/biome": "2.4.0",
    "@commitlint/cli": "20.4.3",
    "@commitlint/config-conventional": "20.4.3",
    "@remotion/bundler": "4.0.443",
    "@remotion/tailwind-v4": "4.0.443",
    "@rolldown/plugin-babel": "0.2.2",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@types/geojson": "7946.0.16",
    "@types/jest": "29.5.12",
    "@types/mapbox-gl": "3.5.0",
    "@types/maplibre-gl": "1.14.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-color": "3.0.13",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "glob": "11.0.3",
    "husky": "9.1.7",
    "jsdom": "29.0.1",
    "tailwindcss": "4.2.2",
    "tsx": "4.16.2",
    "typescript": "5.8.2",
    "vite": "8.0.3",
    "vitest": "4.1.2"
  },
  "lint-staged": {
    "*": "yarn biome:format:fix && yarn biome:lint:fix"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@4.3.1"
}
