{
  "name": "@kalanda/gpxvideostudio",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "scripts/*"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "nx run-many --target=dev --all",
    "build": "nx run-many --target=build --all",
    "start": "nx run-many --target=start --all",
    "test": "nx run-many --target=test --all",
    "test:watch": "nx run-many --target=test --all --watch=true",
    "lint": "nx run-many --target=lint --all",
    "typecheck": "nx run-many --target=typecheck --all",
    "prepare": "husky",
    "commitlint": "commitlint",
    "i18n:check-unused-translations": "tsx scripts/check-unused-translations/src/index.ts --srcPath ./apps/frontend/src --localeFile ./apps/frontend/src/locales/en_US.json && tsx scripts/check-unused-translations/src/index.ts --srcPath ./apps/frontend/src --localeFile ./apps/frontend/src/locales/es_ES.json",
    "i18n:check-locales-structure": "tsx scripts/check-locales-structure/src/index.ts --localesDir ./apps/frontend/src/locales --referenceLocale en_US"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@nx/js": "^22.6.4",
    "@nx/vite": "^22.6.4",
    "@nx/vitest": "^22.6.4",
    "@types/node": "^22",
    "husky": "9.1.7",
    "nx": "^22.6.4",
    "tsx": "4.16.2",
    "typescript": "latest",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@4.3.1"
}
